.venv/
__pycache__/
*.py[cod]
.env
*.egg-info/
.eggs/
dist/
build/

# Local vendored reference dumps (not source)
docs/repomix-*
docs/reference/hermes-agent-reference.txt

# Local GCP deploy env files (may contain project-specific URLs)
.gcloud/

# Local tooling / vendored zips
.claude/
ham-workspace*.zip

# Local run artifacts (pre-ignored for future run persistence)
.ham/
.data/

# Belt-and-suspenders: explicit Social Policy Store paths (already covered by
# .ham/ above, but listed here so deletions of the broader rule cannot
# accidentally unmask user-intent data, backups, or audit envelopes).
.ham/social_policy.json
.ham/social_policy.local.json
.ham/_backups/social_policy/
.ham/_audit/social_policy/

# Frontend
frontend/node_modules/
desktop/node_modules/
src/integrations/cursor_sdk_bridge/node_modules/
desktop/dist-pack/
frontend/dist/
frontend/.env
.vercel
.env*.local

# HAM local / generated tooling (never commit binaries or lab trees)
.cursor/plans/
.cursor/settings.json
desktop/live-smoke/
scripts/cursor_sdk_lab/

# Generated repomix dumps (prefer local regen over committing)
repomix-output-*.txt

# Docs scratch and generated inventories (canonical prose stays tracked)
docs/_scratch/
docs/_generated/
