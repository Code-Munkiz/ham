#!/usr/bin/env bash
# Run HAM operator CLI with repo root on PYTHONPATH.
# Usage: ./scripts/ham doctor
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export PYTHONPATH="${ROOT}${PYTHONPATH:+:${PYTHONPATH}}"
if [[ -x "${ROOT}/.venv/bin/python" ]]; then
  exec "${ROOT}/.venv/bin/python" -m src.ham_cli "$@"
fi
exec python3 -m src.ham_cli "$@"
