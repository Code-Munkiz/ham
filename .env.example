OPENROUTER_API_KEY=
**********************************:free

# --- Sentry error tracking (Phase 1 #9; ADR-0008) ---
# Backend: paste DSN from your Sentry/GlitchTip project. SDK is a no-op when unset.
# SENTRY_DSN=https://xxx@oNNN.ingest.sentry.io/NNN
# Frontend: injected at Vite build time (Vercel env var or .env.local for local dev). No-op when unset.
# VITE_SENTRY_DSN=https://xxx@oNNN.ingest.sentry.io/NNN
# Optional — OpenRouter attribution (recommended in their docs)
# OPENROUTER_HTTP_REFERER=https://localhost
# OPENROUTER_APP_TITLE=Ham

# --- Ham dashboard chat (server-side gateway adapter; browser never sees these) ---
# mock | openrouter (LiteLLM + OPENROUTER_API_KEY) | http (Hermes or any OpenAI-compatible /v1 base)
HERMES_GATEWAY_MODE=mock
# Optional: override the default in-dashboard Ham persona / product context (long text OK, capped server-side).
# HAM_CHAT_SYSTEM_PROMPT=

# For real chat locally: copy this file to `.env`, set HERMES_GATEWAY_MODE=openrouter and OPENROUTER_API_KEY.
# Base URL only (no /v1 suffix), e.g. http://127.0.0.1:8642
HERMES_GATEWAY_BASE_URL=http://127.0.0.1:8642
# Same value as upstream API_SERVER_KEY (Bearer token). On Cloud Run use Secret Manager — do not commit.
HERMES_GATEWAY_API_KEY=
# openrouter: OpenRouter slug (optional; defaults to DEFAULT_MODEL). http (Hermes): e.g. hermes-agent — see Hermes server config.
HERMES_GATEWAY_MODEL=minimax/minimax-m2.5:free
# OpenRouter cost control: In HERMES_GATEWAY_MODE=openrouter, chat uses HERMES_GATEWAY_MODEL if set—otherwise
# DEFAULT_MODEL. If you set a premium model here, every chat can bill at that tier. For cheap mode, set both
# DEFAULT_MODEL and HERMES_GATEWAY_MODEL to the same low-cost slug (e.g. minimax/minimax-m2.5:free) or leave
# HERMES_GATEWAY_MODEL empty so only DEFAULT_MODEL applies. If users pick the "Premium" model in the UI,
# billing uses HAM_CHAT_PREMIUM_MODEL, or HERMES_GATEWAY_MODEL, or—if both unset—anthropic/claude-3.5-sonnet.
# Current free / cheap slugs: see https://openrouter.ai/models
# Private Hermes on GCE + Ham on Cloud Run: HERMES_GATEWAY_MODE=http, HERMES_GATEWAY_BASE_URL=http://<vm-internal-ip>:8642,
# HERMES_GATEWAY_MODEL=hermes-agent, inject HERMES_GATEWAY_API_KEY via Secret Manager. Browser never calls Hermes.
# VPC: Direct VPC egress from Cloud Run preferred; Serverless VPC Access connector as fallback (docs/DEPLOY_CLOUD_RUN.md).
# Optional: composer "Premium" tier (OpenRouter slug). Falls back to HERMES_GATEWAY_MODEL, then claude-3.5-sonnet.
# HAM_CHAT_PREMIUM_MODEL=anthropic/claude-3.5-sonnet
# Optional, opt-in: default model slug for normal conversational chat when the user did not pick a model.
# Unset = previous behavior (HERMES_GATEWAY_MODEL → DEFAULT_MODEL). No paid default is seeded here.
# Precedence: explicit body.model_id > HAM_CHAT_CONVERSATIONAL_MODEL > HERMES_GATEWAY_MODEL > DEFAULT_MODEL.
# Applies to normal conversational/direct-answer chat on both HERMES_GATEWAY_MODE=openrouter
# and HERMES_GATEWAY_MODE=http (per-request Hermes HTTP primary model). Builder, operator,
# agent-router, structured patch/UI-action, critic, harness, and shared helper paths ignore it.
# HAM_CHAT_CONVERSATIONAL_MODEL=
# Optional: OpenRouter slug for Builder Kit LLM scaffolding only (chat build_or_create scaffold path).
# Precedence for scaffold: explicit chat model_id > HAM_SCAFFOLD_MODEL > HAM_PLANNER_MODEL > DEFAULT_MODEL.
# Does not affect conversational chat or Hermes gateway HTTP mode.
# HAM_SCAFFOLD_MODEL=
# REQUIRED for HAM Native Builder: dedicated fast artifact model/profile id for the PRIVATE
# build channel (never user chat). The conversational HERMES_GATEWAY_MODEL (e.g. hermes-agent)
# is too slow to emit a full file bundle within the request budget and times out
# (gateway_code=UPSTREAM_TIMEOUT); native builds fail clearly with a safe "still being
# configured" message until this points to a fast code/artifact model or builder profile.
# http (Hermes): a server-side profile/model id your gateway routes to a fast model.
# openrouter: a fast OpenRouter slug (auto-prefixed with openrouter/ if missing).
# HERMES_BUILDER_MODEL=hermes-builder
# Optional: artifact transport budget in seconds (clamped 30-600, default 300). Independent of
# user-chat SSE guards (HAM_CHAT_HTTP_*). Do not raise above the request/Cloud Run budget.
# HERMES_ARTIFACT_TIMEOUT_SEC=300
# Optional: force streaming for the artifact channel (default prefers one non-streaming turn).
# HERMES_ARTIFACT_STREAM=
# Comma-separated origins for Ham FastAPI CORS (add Vercel preview/prod URLs in deployment)
# HAM_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: regex so every Vercel preview URL matches without listing each (staging-friendly)
# HAM_CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# --- Clerk (identity + org authz for operator turns; optional) ---
# Primary app-wide sign-up restriction: configure Restricted mode + Allowlist in the Clerk Dashboard (see docs/HAM_CHAT_CONTROL_PLANE.md).
# HAM env flags below are defense-in-depth on the API, not a substitute for Clerk Dashboard settings.
#
# When HAM_CLERK_REQUIRE_AUTH or HAM_CLERK_ENFORCE_EMAIL_RESTRICTIONS is true, POST /api/chat and /api/chat/stream
# require Authorization: Bearer <Clerk session JWT> for every request (include `email` in the JWT template for email checks).
# HAM launch/settings/droid secrets must use X-Ham-Operator-Authorization: Bearer <token> when Authorization is the Clerk session.
# HAM_CLERK_REQUIRE_AUTH=true
# Defense-in-depth: enforce comma-separated allowlists (case-insensitive). If true and both lists are empty after parsing, all users are denied.
# HAM_CLERK_ENFORCE_EMAIL_RESTRICTIONS=true
# HAM_CLERK_ALLOWED_EMAILS=alice@company.com,bob@company.com
# HAM_CLERK_ALLOWED_EMAIL_DOMAINS=company.com,partner.org
# Issuer from Clerk dashboard (Frontend API / JWT template), e.g. https://YOUR_INSTANCE.clerk.accounts.dev
# CLERK_JWT_ISSUER=https://YOUR_INSTANCE.clerk.accounts.dev
# Optional: set if your JWT template includes aud and you want strict verification
# CLERK_JWT_AUDIENCE=
# Append-only operator audit JSONL (default ~/.ham/_audit/operator_actions.jsonl). Not stored in Clerk metadata.
# HAM_OPERATOR_AUDIT_FILE=/var/log/ham/operator_actions.jsonl

# --- Connected Tools credential store (Firestore; operators only) ---
# When HAM_WORKSPACE_STORE_BACKEND=firestore, API keys saved from Connected Tools are Fernet-encrypted under collection ``connected_tool_credentials``.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# HAM_CONNECTED_TOOLS_CREDENTIAL_ENCRYPTION_KEY=
# Optional explicit backend override: auto (default), firestore, file / local (plaintext JSON dev fallback).
# HAM_CONNECTED_TOOLS_CREDENTIAL_BACKEND=

# --- Managed Cloud Agent missions (board lane + Hermes advisory writes) ---
# Required for PATCH /api/cursor/managed/missions/{id}/board and POST .../hermes-advisory (Bearer).
# Reads (list/detail/feed/truth/correlation) do not need this. Server-side only — UI may paste per-tab sessionStorage.
# HAM_MANAGED_MISSION_WRITE_TOKEN=generate-a-long-random-secret
# Optional: seconds after which GET mission detail sets hermes_advisory_stale=true (default 900).
# HAM_MANAGED_MISSION_HERMES_STALE_SECONDS=900

# --- Allowlisted project settings writes (v1) ---
# Required for POST /api/projects/{id}/settings/apply and .../rollback (Bearer token).
# Preview does not require this. Do not put this in frontend env — server-side only.
# HAM_SETTINGS_WRITE_TOKEN=generate-a-long-random-secret

# --- Capability library (My library; v1) ---
# Required for POST /api/capability-library/save, /remove, /reorder. Reads do not need it. Server-side only.
# HAM_CAPABILITY_LIBRARY_WRITE_TOKEN=generate-a-different-long-random-secret

# --- Chat operator (mission-control turns; server-side) ---
# Bearer for POST /api/chat operator.phase=launch_run with confirmed=true (bridge + Hermes review + persist under project .ham/runs).
# HAM_RUN_LAUNCH_TOKEN=generate-a-long-random-secret
#
# Factory droid exec (allowlisted workflows; server-side only — never expose to frontend)
# Bearer for operator.phase=droid_launch when workflow requires it (e.g. safe_edit_low). Readonly workflows do not use this.
# HAM_DROID_EXEC_TOKEN=generate-a-long-random-secret
# Optional: delegate droid exec to a remote runner (see docs/FACTORY_DROID_CONTRACT.md, docs/HAM_DROID_RUNNER_SERVICE.md).
# HAM_DROID_RUNNER_URL=https://your-runner.example
# HAM_DROID_RUNNER_TOKEN=shared-secret-ham-to-runner
# HAM_DROID_RUNNER_ID=my-vm-1
# On the *runner* host only (inbound auth for POST /v1/ham/droid-exec): same value as HAM_DROID_RUNNER_TOKEN.
# HAM_DROID_RUNNER_SERVICE_TOKEN=shared-secret-ham-to-runner
# Runner only: comma-separated absolute directories; resolved cwd must live under one (recommended in prod).
# HAM_DROID_RUNNER_ALLOWED_ROOTS=/srv/ham-workspaces,/data/repos
# Runner only: append-only JSONL audit (default ~/.ham/droid_runner_audit.jsonl).
# HAM_DROID_RUNNER_AUDIT_FILE=/var/log/ham/droid_runner_audit.jsonl
# Set false to disable heuristic + structured operator handling (LLM-only chat).
# HAM_CHAT_OPERATOR=true
# Rule-based harness advisory on droid / Cursor agent previews (default off)
# HAM_HARNESS_ADVISORY=1

# --- Chat session persistence (optional) ---
# memory (default) | sqlite — sqlite survives API restarts; default path ~/.ham/chat_sessions.sqlite
# HAM_CHAT_SESSION_STORE=sqlite
# HAM_CHAT_SESSION_DB=/path/to/chat_sessions.sqlite

# Optional — Cursor Cloud API key (same as Dashboard → Cloud Agents). You can also paste a key in
# Ham → Settings → API Keys (saved under ~/.ham/cursor_credentials.json on the API host).
# Used by chat operator Cursor Cloud Agent launch/status (Bearer to api.cursor.com) when set.
# CURSOR_API_KEY=
#
# Optional — enrich managed-mission feed sync via Node @cursor/sdk bridge (see docs/ROADMAP_CLOUD_AGENT_MANAGED_MISSIONS.md).
# Off by default; requires CURSOR_API_KEY and bridge script under src/integrations/cursor_sdk_bridge/.
# HAM_CURSOR_SDK_BRIDGE_ENABLED=true
#
# Bearer for POST /api/chat operator.phase=cursor_agent_launch with confirmed=true (Ham policy gate; not the Cursor key).
# HAM_CURSOR_AGENT_LAUNCH_TOKEN=generate-a-long-random-secret
# Primary audit log for Cursor agent operator actions (default: ~/.ham/_audit/cursor_cloud_agent.jsonl).
# HAM_CURSOR_AGENT_AUDIT_FILE=/var/log/ham/cursor_cloud_agent.jsonl
# Optional demo fallback when project has no metadata.cursor_cloud_repository and operator omits cursor_repository.
# HAM_CURSOR_DEFAULT_REPOSITORY=https://github.com/org/repo
# Optional — absolute path for UI-saved key on Cloud Run/Docker with a mounted volume (survives restarts).
# HAM_CURSOR_CREDENTIALS_FILE=/data/ham/cursor_credentials.json
# Durable control-plane run records (Cursor Cloud Agent + Factory Droid launches); default ~/.ham/control_plane_runs
# HAM_CONTROL_PLANE_RUNS_DIR=/var/lib/ham/control_plane_runs

# --- Workspace Connected Tools: Claude Agent SDK (readiness + optional smoke; not chat orchestration) ---
# Optional package: claude-agent-sdk (pinned in requirements.txt for Cloud Run readiness). Readiness uses
# presence-only checks only (values never returned in API JSON): ANTHROPIC_API_KEY, or CLAUDE_CODE_USE_BEDROCK=1
# plus AWS_REGION or AWS_DEFAULT_REGION, or CLAUDE_CODE_USE_VERTEX=1 plus ANTHROPIC_VERTEX_PROJECT_ID or
# GCLOUD_PROJECT or GOOGLE_CLOUD_PROJECT — see src/ham/worker_adapters/claude_agent_adapter.py.
# ANTHROPIC_API_KEY=
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-1
# CLAUDE_CODE_USE_VERTEX=1
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project
# Optional gated HTTP smoke: POST /api/workspace/tools/claude_agent_sdk/smoke (bounded query(); no tools).
# HAM_CLAUDE_AGENT_SMOKE_ENABLED=1
# When Clerk auth is not used for the request, require this Bearer or X-Ham-Smoke-Token (server-side only).
# HAM_CLAUDE_AGENT_SMOKE_TOKEN=generate-a-long-random-secret

# --- Hermes runtime skills catalog + Phase 2a shared install (see GET /api/hermes-skills/capabilities) ---
# Override Hermes user home for probing (default: ~/.hermes or HERMES_HOME).
# HAM_HERMES_HOME=/path/to/.hermes
# On Cloud Run or other non-co-located hosts, mark remote-only so the UI does not imply installs work:
# HAM_HERMES_SKILLS_MODE=remote_only
# Checkout or extract NousResearch/hermes-agent at the same commit as src/ham/data/hermes_skills_catalog.json upstream.commit.
# Create .ham-hermes-agent-commit in that root with the full 40-char SHA (required for preview/apply).
# HAM_HERMES_SKILLS_SOURCE_ROOT=/path/to/hermes-agent
# Optional: override Hermes config path (default: $HERMES_HOME/config.yaml).
# HAM_HERMES_CONFIG_PATH=/path/to/config.yaml
# Required for POST /api/hermes-skills/install/apply only (Bearer). Preview does not need this.
# HAM_SKILLS_WRITE_TOKEN=generate-a-long-random-secret

# --- Luv Social (extracted; not consumed by HAM API) ---
# Autonomous Telegram/X/Discord social-agent ops moved to luv-protocol/luv-social.
# Env names and runbooks: https://github.com/luv-protocol/luv-social (.env.example, docs/ENVIRONMENT.md)
