OPENROUTER_API_KEY=
DEFAULT_MODEL=openai/gpt-4o-mini
# Optional — OpenRouter attribution (recommended in their docs)
# OPENROUTER_HTTP_REFERER=https://localhost
# OPENROUTER_APP_TITLE=Ham

# --- Ham dashboard chat (server-side gateway adapter; browser never sees these) ---
# mock = no HTTP; http = POST to Hermes API server OpenAI-compatible endpoint
HERMES_GATEWAY_MODE=mock
# Base URL only (no /v1 suffix), e.g. http://127.0.0.1:8642
HERMES_GATEWAY_BASE_URL=http://127.0.0.1:8642
# Same value as upstream API_SERVER_KEY (Bearer token)
HERMES_GATEWAY_API_KEY=
# Model id sent to /v1/chat/completions (cosmetic per upstream docs; default profile uses hermes-agent)
HERMES_GATEWAY_MODEL=hermes-agent
# Comma-separated origins for Ham FastAPI CORS (add Vercel preview/prod URLs in deployment)
# HAM_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
