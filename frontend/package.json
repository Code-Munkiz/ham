{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:comfy": "node scripts/dev-comfy.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,json,md,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{ts,json,md,html}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "dup-check": "jscpd",
    "knip": "knip --no-exit-code",
    "verify:image-intent": "tsx --tsconfig tsconfig.json scripts/run-image-intent-checks.ts"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.8",
    "@google/genai": "^1.52.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/react": "^8.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "jscpd": "^4.2.4",
    "jsdom": "^25.0.1",
    "knip": "^5.62.0",
    "msw": "^2.14.6",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "vite": "^6.4.3",
    "vitest": "^2.1.9"
  }
}
