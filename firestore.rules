rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // PR-1d-B: deny all direct browser/client access.
    // HAM accesses Firestore only through Cloud Run using the Admin SDK
    // and runtime service-account IAM.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
